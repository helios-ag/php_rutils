{
  "name": "andre_487/php_rutils",
  "description": "RUtils is a Russian-specific string utils (transliteration, numeral is words, russian dates, typography)",
  "type": "library",
  "keywords": ["transliteration", "numeral is words", "russian dates", "typography"],
  "homepage": "https://github.com/helios-ag/php_rutils",
  "license": "MIT",
  "repositories": [
    {
      "type": "git",
      "url": "https://github.com/helios-ag/php_rutils"
    }
  ],
  "require": {
    "php": ">=8.3",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpunit/phpunit": "^12.0",
    "vimeo/psalm": "^6.0",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "scripts": {
    "test": "vendor/bin/phpunit --configuration test/phpunit.xml",
    "cs-fix": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes",
    "cs-fix-dry-run": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff --allow-risky=yes",
    "psalm": "vendor/bin/psalm --config=psalm.xml",
    "psalm-check": "vendor/bin/psalm --config=psalm.xml --show-info=false"
  },
  "autoload": {
    "psr-4": {
      "php_rutils\\": "src/"
    }
  }
}
